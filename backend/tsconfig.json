{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "../packages/shared/src/**/*.ts", "../lib/utils/isBusinessOpenNow.ts", "../lib/enums.ts"]
}

